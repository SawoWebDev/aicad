# ── SAWO CAD CMS — environment variables ──
# Copy to .env.local for `vercel dev`, and set these in the Vercel project dashboard for production.

# Supabase project (the live app project is ref: jhymuevfcrqofyqtbkrs)
SUPABASE_URL=https://jhymuevfcrqofyqtbkrs.supabase.co

# Anon / publishable key — used ONLY server-side inside api/auth.js for Supabase Auth sign-in.
# Never shipped to the browser.
SUPABASE_ANON_KEY=

# Service-role key — server-side ONLY. Full DB access, bypasses RLS. NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of THIS CMS deployment. Used to build conversation permalinks for the
# (future) sales email. e.g. https://sawo-cad-cms.vercel.app
APP_URL=http://localhost:3000

# NOTE: the OpenRouter API key is NOT an env var — it lives in the `settings` table and is
# managed from the admin Settings page. Rotate the old leaked key on openrouter.ai and store
# the new one there.
