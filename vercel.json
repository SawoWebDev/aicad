{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/login", "permanent": false }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/cms/conversations/:id", "destination": "/app?conversation=:id" }
  ]
}
